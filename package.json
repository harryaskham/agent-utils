{
  "name": "agent-utils",
  "version": "1.2.2",
  "description": "Agent utilities, MCP servers, and prompt templates",
  "keywords": [
    "pi-package"
  ],
  "author": {
    "name": "Harry Askham"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    ".claude-plugin",
    "extensions",
    "android",
    "prompts",
    "scripts",
    "themes",
    "web-search",
    "crates",
    ".config/ss/config.yaml",
    "Cargo.toml",
    "Cargo.lock",
    "README.md",
    "flake.nix"
  ],
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "npm run docs:build",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "test:coverage:summary": "node scripts/coverage-summary.mjs",
    "check": "npm run lint:workflows && npm run docs:check",
    "lint:workflows": "node scripts/lint-workflows.mjs",
    "docs:build": "node scripts/render-pages.mjs",
    "docs:check": "node scripts/render-pages.mjs --check",
    "pi-graphics:smoke": "node scripts/render-pi-graphics-smoke.mjs",
    "pi-graphics:animation-smoke": "node scripts/kitty-animation-smoke.mjs",
    "pi-graphics:tmux-smoke": "node scripts/test-pi-graphics-tmux-smoke.mjs",
    "pi-graphics:widget-smoke": "node scripts/test-kitty-image-preview-widget-smoke.mjs",
    "kitty-image-preview:render-smoke": "node scripts/kitty-image-preview-multi-image-render-smoke.mjs"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "ws": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/web-search.js",
      "./extensions/kitty-image-preview.js",
      "./extensions/pi-graphics.js",
      "./extensions/firecracker-vm.js",
      "./extensions/realtime-agent.js",
      "./extensions/compaction-continue-guard.js",
      "./extensions/self-compact.js",
      "./extensions/git-behind-warning.js",
      "./extensions/copilot-auth-refresh.js",
      "./extensions/pi-self-update.js",
      "./extensions/effort.js",
      "./extensions/m.js",
      "./extensions/true-defaults.js",
      "./extensions/tendril-share.js",
      "./extensions/app-automation.js",
      "./extensions/android.js",
      "./extensions/xvfb.js"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes/eink.json",
      "./themes/kitty-graphics-nord.json",
      "./themes/kitty-graphics-nord-transparent.json",
      "./themes/kitty-graphics.json"
    ]
  }
}
