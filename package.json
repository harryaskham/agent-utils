{
  "name": "agent-utils",
  "version": "1.0.2",
  "description": "Agent utilities, MCP servers, and prompt templates",
  "keywords": [
    "pi-package"
  ],
  "author": {
    "name": "Harry Askham"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    ".claude-plugin",
    "extensions",
    "prompts",
    "web-search",
    "README.md",
    "flake.nix"
  ],
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "npm run docs:build",
    "test": "node --test",
    "check": "npm run docs:check",
    "docs:build": "node scripts/render-pages.mjs",
    "docs:check": "node scripts/render-pages.mjs --check"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/web-search.js",
      "./extensions/kitty-image-preview.js"
    ],
    "prompts": [
      "./prompts"
    ]
  }
}
