{
  "name": "agent-utils",
  "version": "1.0.3",
  "description": "Agent utilities, MCP servers, and prompt templates",
  "keywords": [
    "pi-package"
  ],
  "author": {
    "name": "Harry Askham"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    ".claude-plugin",
    "extensions",
    "prompts",
    "scripts",
    "themes",
    "web-search",
    "crates",
    ".config/ss/config.yaml",
    "Cargo.toml",
    "Cargo.lock",
    "README.md",
    "flake.nix"
  ],
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "npm run docs:build",
    "test": "node --test",
    "check": "npm run docs:check",
    "docs:build": "node scripts/render-pages.mjs",
    "docs:check": "node scripts/render-pages.mjs --check",
    "pi-graphics:smoke": "node scripts/render-pi-graphics-smoke.mjs",
    "pi-graphics:tmux-smoke": "node scripts/test-pi-graphics-tmux-smoke.mjs"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "ws": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/web-search.js",
      "./extensions/kitty-image-preview.js",
      "./extensions/pi-graphics.js",
      "./extensions/firecracker-vm.js",
      "./extensions/realtime-agent.js",
      "./extensions/pi-self-update.js",
      "./extensions/effort.js",
      "./extensions/true-defaults.js",
      "./extensions/tendril-share.js",
      "./extensions/app-automation.js"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes/kitty-graphics-nord.json",
      "./themes/kitty-graphics.json"
    ]
  }
}
